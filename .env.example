# ── Server ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/automationhub
JWT_SECRET=change_me_to_a_long_random_string
ADMIN_EMAIL=admin@automationhub.ph
ADMIN_PASSWORD_HASH=                      # generate: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"

# GoHighLevel
GHL_API_KEY=                              # Private Integration Token from GHL Developer Settings
GHL_LOCATION_ID=                          # Your GHL sub-account location ID

# CORS
CLIENT_URL=https://www.automationhub.ph

# ── Client ────────────────────────────────────────────────────────────────────
# (put in client/.env)
VITE_API_URL=http://localhost:3001
